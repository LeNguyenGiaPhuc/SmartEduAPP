<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <ScrollView
        android:id="@+id/homeContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/buttonOpenHomeMenu"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="≡"
                    android:textColor="@color/ink"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="SmartEdu"
                    android:textColor="@color/brand_blue_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>



            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Hoạt động gần đây"
                android:textColor="@color/ink"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/emptyRecentSubjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Chưa có môn học được truy cập gần đây."
                android:textColor="@color/ink_muted"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/recentSubjectContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Lịch sử quiz"
                android:textColor="@color/ink"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/emptyHomeQuizHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Chưa có kết quả quiz nào."
                android:textColor="@color/ink_muted"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/homeQuizHistoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/homeMenuBackdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#660F172A"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/homeSideMenu"
        android:layout_width="286dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone"
        app:cardBackgroundColor="@color/paper"
        app:cardCornerRadius="0dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="34dp"
            android:paddingEnd="18dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_avatar"
                    android:gravity="center"
                    android:text="SV"
                    android:textColor="@color/brand_blue_dark"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sinh viên"
                        android:textColor="@color/ink"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="student@smartedu.local"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/buttonCloseHomeMenu"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="×"
                    android:textColor="@color/ink"
                    android:textSize="22sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Menu"
                android:textColor="@color/ink_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonSubjectList"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_badge_blue"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="DS  Danh sách môn học"
                android:textColor="@color/brand_blue_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonLearningHistory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_badge_blue"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="LS  Lịch sử học tập"
                android:textColor="@color/brand_blue_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_action_chip_danger"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Đăng xuất"
                android:textColor="@color/danger"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
