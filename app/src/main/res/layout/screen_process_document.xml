<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backHome"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_pill"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="‹"
                android:textColor="@color/ink"
                android:textSize="34sp" />

            <TextView
                android:id="@+id/textDocName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Tài liệu: Sinh học 10"
                android:textColor="@color/ink"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_document_thumb_blue">

            <ImageView
                android:id="@+id/imageDocPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Ảnh tài liệu"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/imageDocThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="16dp"
                android:text="Chưa có file tài liệu"
                android:textColor="@color/brand_blue_dark"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/imageThumbnailsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/buttonAddMoreImages"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pill"
                    android:backgroundTint="@color/surface_soft"
                    android:gravity="center"
                    android:text="+"
                    android:contentDescription="Thêm tài liệu đính kèm"
                    android:textColor="@color/brand_blue_dark"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <!-- Thumbnails will be added here -->
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/paper"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/line_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nội dung tài liệu"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textContentStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Chưa quét nội dung. Hãy quét tài liệu trước khi dùng AI."
                    android:textColor="@color/ink_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/buttonRunOcr"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_button_blue"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Quét nội dung tài liệu"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonViewDocumentContent"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_action_chip_blue"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Xem nội dung"
                    android:textColor="@color/brand_blue_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Công cụ học tập"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonSummary"
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_blue"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Tóm tắt AI"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonQuestions"
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_orange"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Tạo quiz"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/buttonExplain"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_purple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Hỏi đáp AI"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Quản lý tài liệu"
            android:textColor="@color/ink_muted"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonEditDocument"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_action_chip_blue"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Sửa"
                android:textColor="@color/brand_blue_dark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonDeleteDocumentFromDetail"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_action_chip_danger"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Xóa"
                android:textColor="@color/danger"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
