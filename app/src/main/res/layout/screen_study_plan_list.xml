<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/backFromStudyPlanList"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_pill"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/ink"
            android:textSize="32sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="Kế hoạch học cải thiện"
            android:textColor="@color/ink"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Chỉ hiển thị những lần làm quiz đã được phân tích."
        android:textColor="@color/ink_muted"
        android:textSize="14sp" />

    <Spinner
        android:id="@+id/spinnerPlanSubject"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_badge_blue" />

    <Spinner
        android:id="@+id/spinnerPlanDocument"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_badge_blue" />

    <Spinner
        android:id="@+id/spinnerPlanAttempt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_badge_blue" />

    <TextView
        android:id="@+id/emptyStudyPlans"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Chưa có kế hoạch học nào."
        android:textColor="@color/ink_muted"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/studyPlanListContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />
</LinearLayout>
